# BookTalent — Backend .env template
# --------------------------------------------------------------------
# Copy to  /opt/booktalent/backend/.env  and fill in the real values.
# NEVER commit this file with real secrets.
# --------------------------------------------------------------------

# ── MongoDB ─────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=booktalent

# ── JWT ─────────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 48
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_HEX_STRING
JWT_EXPIRE_MINUTES=1440

# ── Redis (optional — for WebSocket fan-out across multiple workers) ─
# Leave blank to run in-process (single-worker only).
REDIS_URL=redis://localhost:6379/0

# ── Emergent Universal LLM Key (for AI Semantic Search) ─────────────
# Get from  https://emergent.sh  →  Profile  →  Universal Key
EMERGENT_LLM_KEY=

# ── Razorpay (real payments) — leave blank to keep mock mode ────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Resend (transactional emails) — leave blank to log-only ─────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@booktalent.example.com

# ── Twilio (SMS) — leave blank to log-only ──────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Gupshup (WhatsApp) — leave blank to log-only ────────────────────
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_NUMBER=

# ── FCM (push notifications) — leave blank to log-only ──────────────
FCM_SERVER_KEY=

# ── App config ──────────────────────────────────────────────────────
CORS_ORIGINS=https://booktalent.example.com,https://www.booktalent.example.com
ENV=production
