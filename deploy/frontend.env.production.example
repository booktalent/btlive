# BookTalent — Frontend .env template
# --------------------------------------------------------------------
# Copy to  /opt/booktalent/frontend/.env  BEFORE running  yarn build.
# CRA bakes these into the static bundle at build time.
# --------------------------------------------------------------------

# Point to your production API root (Nginx routes /api → backend on 8001)
REACT_APP_BACKEND_URL=https://booktalent.example.com

# Optional: analytics / monitoring keys
# REACT_APP_GA_ID=
# REACT_APP_SENTRY_DSN=
